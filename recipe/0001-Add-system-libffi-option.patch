From d14d02bc6865cb75617640e4a962a7ef3a4261a7 Mon Sep 17 00:00:00 2001
From: Julien Schueller <schueller@phimeca.com>
Date: Thu, 14 May 2026 17:18:52 +0200
Subject: [PATCH] Add system libffi option

---
 CMakeLists.txt         | 21 +++++++++++++++------
 cmake/FindLibFFI.cmake | 25 +++++++++++++++++++++++++
 2 files changed, 40 insertions(+), 6 deletions(-)
 create mode 100644 cmake/FindLibFFI.cmake

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 08d050df..48386be0 100644
--- a/OMCompiler/3rdParty/CMakeLists.txt
+++ b/OMCompiler/3rdParty/CMakeLists.txt
@@ -94,12 +94,21 @@ add_library(omc::3rd::omcgc ALIAS omcgc)
 
 
 
-#libffi
-omc_add_subdirectory(libffi)
-target_include_directories(ffi INTERFACE ${CMAKE_CURRENT_SOURCE_DIR}/libffi/include)
-# Currently the libffi setup puts the configure-generated headers in the
-# `build directory`/include folder
-target_include_directories(ffi INTERFACE ${libffi_BINARY_DIR}/include)
+# libffi
+option(OM_USE_SYSTEM_LIBFFI "Use system libffi" OFF)
+if (OM_USE_SYSTEM_LIBFFI)
+  list(APPEND CMAKE_MODULE_PATH ${CMAKE_CURRENT_SOURCE_DIR}/cmake)
+  find_package(LibFFI REQUIRED)
+  add_library(ffi INTERFACE)
+  target_include_directories(ffi INTERFACE ${LIBFFI_INCLUDE_DIRS})
+  target_link_libraries(ffi INTERFACE ${LIBFFI_LIBRARIES})
+else ()
+  omc_add_subdirectory(libffi)
+  target_include_directories(ffi INTERFACE ${CMAKE_CURRENT_SOURCE_DIR}/libffi/include)
+  # Currently the libffi setup puts the configure-generated headers in the
+  # `build directory`/include folder
+  target_include_directories(ffi INTERFACE ${libffi_BINARY_DIR}/include)
+endif ()
 add_library(omc::3rd::ffi ALIAS ffi)
 
 
diff --git a/cmake/FindLibFFI.cmake b/cmake/FindLibFFI.cmake
new file mode 100644
index 00000000..63fbe184
--- /dev/null
+++ b/OMCompiler/3rdParty/cmake/FindLibFFI.cmake
@@ -0,0 +1,25 @@
+find_package (PkgConfig QUIET)
+pkg_check_modules (PC_LIBFFI QUIET libffi)
+
+# Find the headers and library
+find_path(
+  LIBFFI_INCLUDE_DIR
+  NAMES "ffi.h"
+  HINTS "${PC_LIBFFI_INCLUDE_DIR}")
+
+find_library(
+  LIBFFI_LIBRARY
+  NAMES "ffi"
+  HINTS "${PC_FFI_LIBDIR}")
+
+set (LIBFFI_LIBRARIES ${LIBFFI_LIBRARY})
+set (LIBFFI_INCLUDE_DIRS ${LIBFFI_INCLUDE_DIR})
+
+include(FindPackageHandleStandardArgs)
+find_package_handle_standard_args(LibFFI DEFAULT_MSG LIBFFI_LIBRARY LIBFFI_INCLUDE_DIRS)
+
+mark_as_advanced (
+  LIBFFI_LIBRARY
+  LIBFFI_LIBRARIES
+  LIBFFI_INCLUDE_DIR
+  LIBFFI_INCLUDE_DIR)
-- 
2.54.0

